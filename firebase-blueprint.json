{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents a user in the SkillSwap marketplace.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "credits": { "type": "number", "description": "Time credits balance (1 credit = 1 hour)" },
        "bio": { "type": "string" },
        "skillsToTeach": { "type": "array", "items": { "type": "string" } },
        "skillsToLearn": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "credits", "createdAt"]
    },
    "Skill": {
      "title": "Skill Listing",
      "description": "A skill offer posted by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "level": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "title", "description", "level", "createdAt"]
    },
    "Session": {
      "title": "Learning Session",
      "description": "A scheduled or completed skill exchange session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "mentorId": { "type": "string" },
        "learnerId": { "type": "string" },
        "skillId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed", "cancelled"] },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "creditsExchanged": { "type": "number" },
        "mentorNote": { "type": "string" },
        "learnerFeedback": { "type": "string" },
        "rating": { "type": "number" }
      },
      "required": ["mentorId", "learnerId", "skillId", "status", "scheduledAt", "durationMinutes"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and credit balances"
    },
    "skills/{skillId}": {
      "schema": "Skill",
      "description": "Public skill offers"
    },
    "sessions/{sessionId}": {
      "schema": "Session",
      "description": "Private exchange sessions between two users"
    }
  }
}
